PTERODACTYL_APP_API_KEY=your-application-api-key
# Required for power control (start/stop/restart) and live server status.
# Must be a CLIENT API key (starts with "ptlc_"), created under the panel account
# that owns the servers (Account Settings > API Credentials).
PTERODACTYL_CLIENT_API_KEY=ptlc_your-client-api-key

