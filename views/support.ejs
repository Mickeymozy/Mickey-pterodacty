<%- include('partials/header') %>

<main class="mx-auto flex max-w-7xl flex-col gap-8 px-4 py-10 sm:px-6 lg:px-8">
  <section class="grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
    <article class="rounded-3xl border border-white/10 bg-white/5 p-6 shadow-2xl shadow-black/30 backdrop-blur-xl">
      <p class="text-sm uppercase tracking-[0.35em] text-cyan-200/80">Support center</p>
      <h1 class="mt-4 text-3xl font-black text-white sm:text-4xl">Priority help for critical incidents</h1>
      <p class="mt-4 text-slate-300">Use AI-assisted triage, track conversations, and escalate issues quickly through the same control panel your clients use.</p>
      <button class="mt-6 rounded-full bg-gradient-to-r from-cyan-400 to-sky-500 px-4 py-2 text-sm font-semibold text-slate-950 hover:opacity-95">Open ticket</button>
    </article>

    <article class="rounded-3xl border border-white/10 bg-slate-950/90 p-6 shadow-2xl shadow-black/30">
      <p class="text-sm uppercase tracking-[0.35em] text-cyan-200/80">Response SLA</p>
      <div class="mt-4 space-y-4 text-sm text-slate-200">
        <div class="rounded-2xl border border-white/10 bg-white/5 p-4">Critical outages: <strong class="text-white">15 min</strong></div>
        <div class="rounded-2xl border border-white/10 bg-white/5 p-4">Performance issues: <strong class="text-white">1 hr</strong></div>
        <div class="rounded-2xl border border-white/10 bg-white/5 p-4">Billing questions: <strong class="text-white">same business day</strong></div>
      </div>
    </article>
  </section>

  <section class="rounded-3xl border border-white/10 bg-white/5 p-6 shadow-2xl shadow-black/30 backdrop-blur-xl">
    <h2 class="text-xl font-semibold text-white">Recent tickets</h2>
    <div class="mt-6 space-y-4">
      <% tickets.forEach((ticket) => { %>
        <article class="rounded-2xl border border-white/10 bg-slate-950/85 p-4">
          <div class="flex flex-wrap items-center justify-between gap-4">
            <div>
              <p class="text-lg font-semibold text-white"><%= ticket.subject %></p>
              <p class="text-sm text-slate-400"><%= ticket.id %> • Updated <%= ticket.updated %></p>
            </div>
            <div class="flex items-center gap-3">
              <span class="rounded-full bg-amber-500/10 px-3 py-1 text-xs font-semibold text-amber-200"><%= ticket.priority %></span>
              <span class="rounded-full bg-cyan-500/10 px-3 py-1 text-xs font-semibold text-cyan-200"><%= ticket.status %></span>
            </div>
          </div>
        </article>
      <% }); %>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
