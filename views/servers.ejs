<%- include('partials/header') %>

<main class="mx-auto flex max-w-7xl flex-col gap-8 px-4 py-10 sm:px-6 lg:px-8">
  <section class="rounded-3xl border border-white/10 bg-white/5 p-6 shadow-2xl shadow-black/30 backdrop-blur-xl">
    <p class="text-sm uppercase tracking-[0.35em] text-cyan-200/80">Server management</p>
    <h1 class="mt-4 text-3xl font-black text-white sm:text-4xl">Fleet control and automation</h1>
    <p class="mt-4 max-w-3xl text-slate-300">Reboot, inspect, and monitor every managed hosting node from a single operator console with instant status visibility.</p>
  </section>

  <section class="grid gap-6 lg:grid-cols-2">
    <% servers.forEach((server) => { %>
      <article class="rounded-3xl border border-white/10 bg-white/5 p-6 shadow-2xl shadow-black/30 backdrop-blur-xl">
        <div class="flex items-start justify-between gap-6">
          <div>
            <p class="text-sm uppercase tracking-[0.35em] text-cyan-200/80"><%= server.plan %></p>
            <h2 class="mt-3 text-2xl font-semibold text-white"><%= server.name %></h2>
            <p class="mt-2 text-slate-300"><%= server.location %> • <%= server.disk %></p>
          </div>
          <span class="rounded-full px-3 py-1 text-xs font-semibold <%= server.badge %>"><%= server.status %></span>
        </div>
        <dl class="mt-6 grid gap-4 text-sm text-slate-200 sm:grid-cols-2">
          <div class="rounded-2xl border border-white/10 bg-slate-950/80 p-4"><dt class="text-slate-400">CPU</dt><dd class="mt-1 text-white"><%= server.cpu %></dd></div>
          <div class="rounded-2xl border border-white/10 bg-slate-950/80 p-4"><dt class="text-slate-400">RAM</dt><dd class="mt-1 text-white"><%= server.ram %></dd></div>
          <div class="rounded-2xl border border-white/10 bg-slate-950/80 p-4"><dt class="text-slate-400">Traffic</dt><dd class="mt-1 text-white"><%= server.traffic %></dd></div>
          <div class="rounded-2xl border border-white/10 bg-slate-950/80 p-4"><dt class="text-slate-400">Backup</dt><dd class="mt-1 text-white"><%= server.next_backup %></dd></div>
        </dl>
        <div class="mt-6 flex flex-wrap gap-3">
          <button data-reboot="<%= server.id %>" class="rounded-full bg-gradient-to-r from-cyan-400 to-sky-500 px-4 py-2 text-sm font-semibold text-slate-950 hover:opacity-95">Reboot node</button>
          <button class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-slate-100 hover:border-cyan-400/60 hover:bg-cyan-400/10">Open console</button>
          <button class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-slate-100 hover:border-cyan-400/60 hover:bg-cyan-400/10">Schedule backup</button>
        </div>
      </article>
    <% }); %>
  </section>
</main>

<%- include('partials/footer') %>
